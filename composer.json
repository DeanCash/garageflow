{
    "name": "garagesandvos/garageflow",
    "description": "GarageFlow - afspraken- en werkordersysteem voor Garage Sandvos",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "GarageFlow\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "GarageFlow\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
